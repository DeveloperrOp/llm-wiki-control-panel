# Normalize line endings consistently across Windows / macOS / Linux

* text=auto eol=lf

# Python / shell / md — always LF
*.py     text eol=lf
*.sh     text eol=lf
*.command text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.txt    text eol=lf

# Windows scripts — always CRLF
*.bat    text eol=crlf
*.ps1    text eol=crlf

# Images — binary
*.png    binary
*.jpg    binary
*.gif    binary
